{
  "name": "lush-laundry-backend",
  "version": "1.0.0",
  "description": "Backend API for Lush Laundry ERP System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register src/database/migrate.ts",
    "seed": "node -r ts-node/register src/database/seed.ts",
    "db:reset": "npm run migrate && npm run seed",
    "show:credentials": "node -r ts-node/register src/showCredentials.ts",
    "show:users": "node -r ts-node/register src/showAllUsers.ts",
    "create:staff": "node -r ts-node/register src/createStaffAccounts.ts",
    "reset:passwords": "node -r ts-node/register src/resetStaffPasswords.ts",
    "enable:dual-auth": "node -r ts-node/register src/enableDualAuth.ts",
    "audit:phase1": "node -r ts-node/register src/audit/phase1-database.ts",
    "audit:phase2": "node -r ts-node/register src/audit/phase2-financial.ts",
    "audit:phase3": "node -r ts-node/register src/audit/phase3-authentication.ts",
    "audit:phase4": "node -r ts-node/register src/audit/phase4-api-correspondence.ts",
    "audit:phase5": "node -r ts-node/register src/audit/phase5-ui-ux.ts",
    "audit:phase6": "node -r ts-node/register src/audit/phase6-business-logic.ts",
    "audit:phase7": "node -r ts-node/register src/audit/phase7-reporting-analytics.ts",
    "audit:phase8": "node -r ts-node/register src/audit/phase8-system-reliability.ts",
    "audit:phase9": "node -r ts-node/register src/audit/phase9-security.ts",
    "audit:phase10": "node -r ts-node/register src/audit/phase10-edge-cases.ts",
    "utils:find-duplicates": "node -r ts-node/register src/utils/find-duplicate-customers.ts",
    "utils:merge-duplicates": "node -r ts-node/register src/utils/merge-duplicate-customers.ts",
    "fix:order-totals": "node -r ts-node/register src/audit/fix-order-totals.ts",
    "fix:discount-totals": "node -r ts-node/register src/audit/fix-discount-totals.ts",
    "verify:money-format": "node -r ts-node/register src/audit/verify-money-formatting.ts",
    "verify:discounts": "node -r ts-node/register src/audit/verify-discount-display.ts",
    "verify:percentages": "node -r ts-node/register src/audit/verify-percentage-calculations.ts"
  },
  "keywords": [
    "laundry",
    "erp",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.4",
    "africastalking": "^0.7.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.3.1",
    "framer-motion": "^12.33.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "twilio": "^5.11.2"
  },
  "devDependencies": {
    "@types/africastalking": "^0.6.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.11.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
