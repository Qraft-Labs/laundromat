# Backend Production Environment Variables
# Copy this to .env on your production server and update with actual values

# CRITICAL: Change NODE_ENV to production
NODE_ENV=production

# Server Configuration
PORT=5000

# Database Configuration - USE PRODUCTION DATABASE CREDENTIALS
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lush_laundry_prod
DB_USER=lush_admin
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# JWT Configuration - GENERATE NEW SECRET FOR PRODUCTION
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_GENERATE_WITH_OPENSSL_RAND_BASE64_32
JWT_EXPIRES_IN=7d

# Session Configuration - GENERATE NEW SECRET FOR PRODUCTION
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_THIS_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# CORS Configuration - SET YOUR PRODUCTION FRONTEND URL
FRONTEND_URL=https://your-app.netlify.app

# Google OAuth Configuration
# Update redirect URIs in Google Cloud Console:
# - https://api.yourdomain.com/auth/google/callback
# - https://your-app.netlify.app
# - https://yourdomain.com
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/auth/google/callback

# Authorized Admin Emails (comma-separated)
AUTHORIZED_ADMIN_EMAILS=admin@yourdomain.com

# WhatsApp Configuration (Twilio) - Optional
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMS Configuration (Africa's Talking) - Optional
SMS_ENABLED=false
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_USERNAME=your_username_here
SMS_SENDER_ID=LUSHLAUNDRY
BUSINESS_HOURS=Mon-Sat: 7:00 AM - 9:00 PM

# Email Configuration (Gmail) - Optional
# For Gmail, generate an "App Password" from Google Account settings
EMAIL_USER=your-business-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# SECURITY CHECKLIST BEFORE DEPLOYMENT:
# ✅ Change all secrets (JWT_SECRET, SESSION_SECRET)
# ✅ Use strong database password
# ✅ Update FRONTEND_URL to your production domain
# ✅ Update GOOGLE_CALLBACK_URL to production URL
# ✅ Add production URLs to Google Cloud Console redirect URIs
# ✅ Set NODE_ENV=production
# ✅ Update AUTHORIZED_ADMIN_EMAILS with real admin emails
# ✅ Never commit this .env file to git
