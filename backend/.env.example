# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lush_laundry
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Session Configuration
# Generate strong secret: openssl rand -base64 32
SESSION_SECRET=your_session_secret_min_32_chars_random_string

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Authorized Admin Emails (comma-separated)
# Only these emails can register as admins via Google OAuth
AUTHORIZED_ADMIN_EMAILS=admin@yourdomain.com,admin2@yourdomain.com

# WhatsApp Configuration (Twilio)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMS Configuration (Africa's Talking)
SMS_ENABLED=false
AFRICASTALKING_API_KEY=your_api_key_here
AFRICASTALKING_USERNAME=your_username_here
AFRICASTALKING_WA_NUMBER=+254799999999
SMS_SENDER_ID=LUSHLAUNDRY
BUSINESS_HOURS=Mon-Sat: 7:00 AM - 9:00 PM

# INSTRUCTIONS TO GET SMS/WHATSAPP CREDENTIALS:
# 1. Sign up at https://africastalking.com
# 2. Go to Dashboard → Settings → API Key
# 3. Copy your API Key and Username
# 4. For WhatsApp:
#    - Go to WhatsApp section
#    - Request WhatsApp Business API access
#    - Get your WhatsApp Business number (waNumber)
#    - Use Simulator for testing: Tools → Simulator
# 5. Register SMS sender ID (optional) - takes 1-2 days for approval
# 6. Add credits to your account (UGX 35 per SMS in Uganda)
# 7. Set SMS_ENABLED=true when ready to send real messages
# 8. For testing, keep SMS_ENABLED=false (will log messages only)